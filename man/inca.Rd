\examples{
# Multivariate normal target (D = 10, equicorrelation rho = 0.9).
# Requires a working CUDA toolchain and CMCMC configured via `cmcmcopt()`.
\dontrun{
library(CMCMC)

# Set CUDA paths (edit for your system).
CMCMC::cmcmcopt(PATH = "/usr/local/cuda/bin",
                      DYLD_LIBRARY_PATH = "/usr/local/cuda/lib64")

D <- 10
rho <- 0.9
mu <- rep(0, D)
Sigma <- matrix(rho, nrow = D, ncol = D)
diag(Sigma) <- 1

# MVNorm kernel expects X = c(mu, SigmaInv) with SigmaInv in column-major order.
X <- c(mu, as.numeric(solve(Sigma)))
Xi <- integer(0)

# Run INCA with K particles and T iterations.
K <- 1024
T <- 2500
samples <- CMCMC::inca(
  init = mu,
  GPUkernel = "MVNorm",
  it = T,
  covit = 5,
  p = K,
  X = X,
  Xi = Xi,
  saved_iterations = 1,
  seed = 123,
  device = 0
)

# Posterior sample is the last population (K draws in R^D).
dim(samples)
colMeans(samples[, 3:(2 + D), drop = FALSE])
}

}
